---
export interface Props {
  tech: string;
  size?: 'sm' | 'md';
}
const { tech, size = 'sm' } = Astro.props;
const sizeClass = size === 'sm' ? 'px-2 py-0.5 text-xs' : 'px-2.5 py-1 text-sm';
---

<span class:list={['inline-flex items-center rounded-md border border-[var(--line)] bg-[var(--bg-2)] font-mono text-[var(--fg-2)]', sizeClass]}>
  {tech}
</span>
