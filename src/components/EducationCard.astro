---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '@i18n/utils';
import { t, formatDate } from '@i18n/utils';
import { Icon } from 'astro-icon/components';

export interface Props { entry: CollectionEntry<'education'>; locale: Locale; }
const { entry, locale } = Astro.props;
const data = entry.data;
const dateRange = `${formatDate(locale, data.startDate)} — ${data.current ? t(locale, 'labels.present') : formatDate(locale, data.endDate ?? null)}`;
---

<article class="card flex flex-col gap-2 p-5 sm:p-6">
  <header class="flex items-baseline justify-between gap-4 flex-wrap">
    <h3 class="text-base font-semibold text-[var(--fg)]">{data.qualification}</h3>
    <span class="font-mono text-xs text-[var(--fg-2)]">{dateRange}</span>
  </header>
  <p class="text-sm text-[var(--fg-2)]">
    <Icon name="lucide:graduation-cap" class="mr-1 inline h-4 w-4 -translate-y-px" />
    {data.institution} · {data.location}
  </p>
  <p class="mt-1 text-sm leading-relaxed text-[var(--fg-2)]">{data.summary}</p>
</article>
