---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '@i18n/utils';
import { t, path, stripLocaleFromId } from '@i18n/utils';
import { Icon } from 'astro-icon/components';
import TechBadge from './TechBadge.astro';

export interface Props {
  entry: CollectionEntry<'projects'>;
  locale: Locale;
}
const { entry, locale } = Astro.props;
const slug = stripLocaleFromId(entry.id);
const data = entry.data;
const detailHref = path(locale, 'projects', slug);
---

<article class="card group relative flex flex-col gap-3 p-5 sm:p-6">
  <a
    href={detailHref}
    class="absolute inset-0 z-0 rounded-[inherit]"
    aria-label={`${t(locale, 'actions.viewProject')}: ${data.title}`}
  ></a>

  <header class="relative z-10 flex items-start justify-between gap-3">
    <h3 class="text-lg font-semibold text-[var(--fg)] group-hover:text-[var(--link)]">
      {data.title}
    </h3>
    <div class="flex shrink-0 items-center gap-1">
      {data.featured && (
        <Icon name="lucide:star" class="h-4 w-4 text-[var(--color-accent-500)]" aria-label="Featured" />
      )}
      <span class="rounded-md bg-[var(--bg-2)] px-2 py-0.5 font-mono text-xs text-[var(--fg-2)]">
        {data.year}
      </span>
    </div>
  </header>

  <p class="relative z-10 text-sm leading-relaxed text-[var(--fg-2)]">
    {data.summary}
  </p>

  <div class="relative z-10 mt-auto flex flex-wrap gap-1.5">
    {data.tech.slice(0, 6).map((t) => <TechBadge tech={t} />)}
    {data.tech.length > 6 && (
      <span class="font-mono text-xs text-[var(--fg-2)]">+{data.tech.length - 6}</span>
    )}
  </div>

  <footer class="relative z-10 flex items-center gap-3 text-xs text-[var(--fg-2)]">
    <span class="inline-flex items-center gap-1">
      <Icon name="lucide:tag" class="h-3.5 w-3.5" />
      {t(locale, `categories.${data.category}`)}
    </span>
    <span>·</span>
    <span>{t(locale, `statuses.${data.status}`)}</span>

    <span class="ml-auto flex items-center gap-2">
      {data.links?.repo && (
        <a href={data.links.repo} rel="noopener" class="relative z-20 inline-flex h-7 w-7 items-center justify-center rounded-md hover:bg-[var(--bg-2)] hover:text-[var(--fg)]" aria-label={t(locale, 'actions.viewCode')}>
          <Icon name="simple-icons:github" class="h-3.5 w-3.5" />
        </a>
      )}
      {data.links?.live && (
        <a href={data.links.live} rel="noopener" class="relative z-20 inline-flex h-7 w-7 items-center justify-center rounded-md hover:bg-[var(--bg-2)] hover:text-[var(--fg)]" aria-label={t(locale, 'actions.viewLive')}>
          <Icon name="lucide:external-link" class="h-3.5 w-3.5" />
        </a>
      )}
    </span>
  </footer>
</article>
