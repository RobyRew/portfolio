---
export interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  as?: 'h1' | 'h2' | 'h3';
}
const { eyebrow, title, description, as: Tag = 'h2' } = Astro.props;
---

<header class="mb-6 sm:mb-8">
  {eyebrow && (
    <p class="mb-2 font-mono text-xs uppercase tracking-widest text-[var(--color-accent-600)] dark:text-[var(--color-accent-400)]">
      {eyebrow}
    </p>
  )}
  <Tag class="text-2xl font-bold tracking-tight text-[var(--fg)] sm:text-3xl">
    {title}
  </Tag>
  {description && (
    <p class="mt-2 max-w-2xl text-base text-[var(--fg-2)] sm:text-lg">
      {description}
    </p>
  )}
</header>
